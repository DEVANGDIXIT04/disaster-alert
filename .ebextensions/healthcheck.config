# .ebextensions/healthcheck.config
# Elastic Beanstalk reads every .config file in this folder on deploy.
# This one tells the environment to probe GET /api/health (instead of "/")
# to decide whether the app is healthy. Only used in a load-balanced
# environment; a --single environment ignores it harmlessly.
option_settings:
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/health
