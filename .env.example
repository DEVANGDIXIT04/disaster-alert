# Copy to .env (or export these) to override the defaults.
# Both variables are OPTIONAL for local development - the app falls back to
# SQLite and a dev JWT secret (with a printed warning).

# Where the database lives.
#   local default : sqlite:///<project folder>/local.db   (no setup needed)
#   docker compose: postgresql://disaster:disaster123@db:5432/disaster
#   AWS RDS       : postgresql://USER:PASSWORD@ENDPOINT:5432/DBNAME
DATABASE_URL=

# Secret used to sign JWTs. Anyone who knows it can forge logins,
# so use a long random string in production:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
